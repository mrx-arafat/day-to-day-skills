# Notion API Configuration (NEVER commit actual tokens!)
# Copy this file to .env and fill in your actual token

# Get your token from: https://www.notion.so/my-integrations
# DO NOT share or commit this value
NOTION_API_TOKEN=ntn_your_actual_token_here

# Optional: Default parent page ID (if not found automatically)
# NOTION_PARENT_PAGE_ID=your_page_id_here
